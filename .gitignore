# Local Python environments
.venv/
.venv-*/
venv/
env/

# Local secrets / environment files — never commit (e.g. RUNPOD_API_KEY in .env).
# Note: `env/` above only matches a directory; a bare `.env` file needs its own rule.
.env
.env.*
!.env.example

# Python caches and test output
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/

# Local benchmark / solver outputs
csg_benchmark_out/
csg_solve_out/
scene_out/
*_out/
CSG_Solver_Harness/csg_harness_final_benchmark/

# Build / release artifacts
build/
dist/
*.egg-info/
phase2e_release/
phase2e_release_out/

# RLBench external-trace pilot: live demos + generated rollouts/sidecars.
# The small synthetic fixture (pilots/rlbench/fixtures/*.rollout.json) stays committed;
# only the live recorder's outputs are ignored (pilots/rlbench/_out already matches
# *_out/ above; listed explicitly here alongside the recorded-demo directory).
pilots/rlbench/_out/
pilots/rlbench/_demos/

# Real-camera pilot (Phase 3A): raw Sony/tripod footage is NEVER committed — only small
# derived JSON (calibration, tracks, rollouts, reports) + manifest.json with the raw
# video's sha256 + path. Raw video lives under any raw_videos/ dir and matches by extension.
datasets/**/raw_videos/
*.MP4
*.MOV
*.mp4
*.mov
pilots/real_camera/_out/

# RH20T external-source pilot (Phase 3A.5): raw media and extraction scratch are too
# large/sensitive for git. Commit ONLY derived JSON (annotations, tracks, rollouts,
# reports) + provenance hashes; raw archives, extracted trees, and frame dumps stay on
# RunPod. (*.mp4/*.MP4 are already globally ignored above.)
datasets/rh20t_object_inside_container_v0/raw/
datasets/rh20t_object_inside_container_v0/frame_dumps/
datasets/rh20t_object_inside_container_v0/extracted/
datasets/rh20t_object_inside_container_v0/**/*.tar.gz
datasets/rh20t_object_inside_container_v0/**/*.npy

# MuJoCo / local logs
MUJOCO_LOG.TXT
*.log

# OS/editor noise
.DS_Store
.idea/
.vscode/

# Private / internal notes — never publish to the open-source repo
.internal/

# Real-camera pilot scratch: regenerable overlays, helper images, and local ingest runs.
# Committed dataset artifacts live under datasets/; raw mp4s and these derived outputs do not.
output/
